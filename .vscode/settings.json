{
  "Lua.runtime.version": "Lua 5.4",
  "Lua.workspace.library": [
    "C:/gitProjects/Lmaobox-Annotations/library"
  ],
  "Lua.workspace.checkThirdParty": true,
  "files.autoSave": "onFocusChange",
  "achilleshr.runonsave": {
    "commands": [
      {
        "match": ".*[\\\\/]src[\\\\/].*\\.lua$",
        "isAsync": true,
        "cmd": "if exist \"${workspaceFolder}\\bundle-and-deploy.js\" node \"${workspaceFolder}\\bundle-and-deploy.js\"",
        "autoShowOutputPanel": "always"
      }
    ]
  }
}
